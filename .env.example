# internal-author-marker: Muhammad Waseem Akram

# -- Core Paths --------------------------------------------
REPO_ROOT=.
EXPERT_DIR=./experts/base
EXPERT_REGISTRY_PATH=./experts/registry.json
LORA_DIR=./experts/lora
CHROMA_DIR=./data/chroma
SQLITE_DIR=./data/sqlite
VECTOR_INDEX_PATH=./data/chroma/memory.index

# -- Router ------------------------------------------------
ROUTER_BACKEND=auto
ROUTER_MODEL_PATH=./experts/router.json
ROUTER_CONFIDENCE_THRESHOLD=0.7
GRPC_HOST=127.0.0.1
GRPC_PORT=50051
GRPC_TIMEOUT_SEC=0.5

# -- Embeddings And Memory --------------------------------
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
MEMORY_VECTOR_BACKEND=auto
MEMORY_RECALL_LIMIT=10
MEMORY_DECAY_DAYS=90

# -- Internet ----------------------------------------------
INTERNET_ENABLED=true
INTERNET_MAX_REQUESTS_PER_QUERY=5
INTERNET_CACHE_TTL_SECONDS=3600
INTERNET_ALLOWED_DOMAINS=
HTTP_TIMEOUT_SEC=10.0
HTTP_USER_AGENT=LatticeBrain/0.1
HTTP_ALLOW_INSECURE_TLS=false

# -- Voice -------------------------------------------------
WHISPER_MODEL=small
VOICE_SAMPLE_RATE=16000

# -- Expert Pool -------------------------------------------
EXPERT_MAX_LOADED=3
EXPERT_IDLE_TIMEOUT_SEC=30

# -- Learning ----------------------------------------------
LEARNING_ENABLED=true
LEARNING_BACKEND=auto
LEARNING_MIN_SIGNAL_STRENGTH=0.6
LEARNING_CORRECTION_BATCH_SIZE=8

# -- Interface And Runtime --------------------------------
API_PORT=8080
LOG_LEVEL=info
MAX_CITATIONS=4
STRICT_RUNTIME=true
