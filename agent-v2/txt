(* Demo: Factorial and List Operations *)
let rec factorial n =
  if n <= 1 then 1 else n * factorial (n - 1)

let numbers = [1; 2; 3; 4; 5]

let squares = List.map (fun x -> x * x) numbers

let () =
  print_endline "=== Agent v2 Demo Output ===";
  List.iter (fun x -> Printf.printf "Square: %d\n" x) squares;
  Printf.printf "Factorial of 5: %d\n" (factorial 5);
  print_endline "==========================="

